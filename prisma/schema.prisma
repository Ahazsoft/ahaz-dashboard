generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model applicants {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id        String    @db.Uuid
  first_name    String
  last_name     String
  email         String
  phone         String?
  github_link   String?
  linkedin_link String?
  cv_url        String
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  jobs          jobs      @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model jobs {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company     String       @default("Ahaz Solutions")
  title       String
  job_type    String
  job_level   String
  location    String
  salary      String
  description String
  education   String
  email       String
  post_date   DateTime     @default(now()) @db.Timestamptz(6)
  expiry_date DateTime     @db.Timestamptz(6)
  status      job_status   @default(open)
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?    @default(now()) @db.Timestamptz(6)
  applicants  applicants[]
}

enum job_status {
  open
  closed
}
